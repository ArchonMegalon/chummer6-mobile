@page "/mobile"
@page "/mobile/player"
@page "/mobile/gm"
@page "/mobile/observer"
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <link rel="manifest" href="@ManifestHref" />
    <meta name="apple-mobile-web-app-title" content="@AppleAppTitle" />
    <link rel="stylesheet" href="/mobile.css" />
    <script src="/mobile-install-shell.js" defer></script>
</HeadContent>

<main class="turn-shell install-only-shell"
      data-play-surface="install-only"
      data-live-session="unavailable"
      data-authority="none">
    <section class="turn-card hero install-hero">
        <div>
            <p class="eyebrow">Chummer Play · install shell</p>
            <h1>Install the companion. Join play from a trusted invitation.</h1>
            <p class="lede">
                This public page never opens table state and does not create a Play session.
                Install it now, then sign in or scan an invitation from your table when live access is available.
            </p>
        </div>

        <div class="trust-strip" aria-label="Public install boundary">
            <span class="status-pill status-pill--cool">Public shell only</span>
            <span class="status-pill">No table data loaded</span>
            <span class="status-pill">No role granted</span>
        </div>

        <div class="install-surface install-actions">
            <button id="turn-install-button" type="button" class="primary-button">
                Install app
            </button>
            <a class="secondary-button" href="/login">Sign in</a>
            <a class="secondary-button" href="/participate">How to join</a>
        </div>
        <p id="turn-install-status" class="support-copy" role="status" aria-live="polite">
            Use your browser menu to install this app. A direct install button appears when your browser supports it.
        </p>
        <div id="turn-manual-install-help" class="support-copy manual-install-help" tabindex="-1">
            <p><strong>iPhone or iPad:</strong> in Safari, choose Share, then Add to Home Screen.</p>
            <p><strong>Android:</strong> open the browser menu, then choose Install app or Add to Home screen.</p>
            <p>If your browser offers neither command, keep using this public install shell in the browser.</p>
        </div>
    </section>

    <section class="install-boundary-grid" aria-label="How Chummer Play access works">
        <article class="turn-card">
            <p class="eyebrow">1 · Install</p>
            <h2>Keep the public shell on this device.</h2>
            <p class="support-copy">
                Installation stores only public shell assets. It does not cache a character, campaign, table projection,
                continuity secret, or session grant.
            </p>
        </article>
        <article class="turn-card">
            <p class="eyebrow">2 · Sign in or scan</p>
            <h2>Use an invitation issued by your table.</h2>
            <p class="support-copy">
                A trusted invitation must resolve to your signed-in Hub identity and a server-side Play session grant.
                Typed session ids, role parameters, and service keys cannot grant access.
            </p>
        </article>
        <article class="turn-card">
            <p class="eyebrow">3 · Join</p>
            <h2>Live sessions are not available from this link.</h2>
            <p class="support-copy">
                Return through the invitation after access has been granted. Until then, Player, Observer, and GM URLs
                are install labels only; they confer no table role or authority.
            </p>
        </article>
    </section>

    @if (IsGmLabel)
    {
        <section class="turn-card role-warning" role="note">
            <p class="eyebrow">GM safety boundary</p>
            <h2>This URL does not grant Game Master authority.</h2>
            <p class="support-copy">
                GM controls become available only after a signed-in identity receives an authoritative server-side grant
                for a specific Play session.
            </p>
        </section>
    }
</main>

@code {
    private string RoutePath => new Uri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();

    private bool IsGmLabel => RoutePath == "/mobile/gm";

    private string ManifestHref => RoutePath switch
    {
        "/mobile/gm" => "/manifest.gm.webmanifest",
        "/mobile/player" => "/manifest.player.webmanifest",
        "/mobile/observer" => "/manifest.observer.webmanifest",
        _ => "/manifest.webmanifest"
    };

    private string PageTitleText => RoutePath switch
    {
        "/mobile/gm" => "Install Chummer GM Companion",
        "/mobile/player" => "Install Chummer Player Companion",
        "/mobile/observer" => "Install Chummer Observer Companion",
        _ => "Install Chummer Play"
    };

    private string AppleAppTitle => RoutePath switch
    {
        "/mobile/gm" => "Chummer GM",
        "/mobile/player" => "Chummer Player",
        "/mobile/observer" => "Chummer Observer",
        _ => "Chummer Play"
    };
}
